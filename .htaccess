# Disable directory listings
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Prevent rewriting of physical files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite API routes to our PHP controller inside the /backend folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api/(.*)$ backend/api.php?route=$1 [QSA,L]

    # Send all other virtual frontend requests into index.html for SPA rendering
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.html [L]
</IfModule>
